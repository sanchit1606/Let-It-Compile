# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Environments
.venv/
venv/
ENV/
.env/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.vscode/

# Build / packaging
build/
dist/
*.egg-info/

# Logs
*.log

# Paper (LaTeX)
# Ignore build outputs generated in Paper/, but keep the source tracked.
Paper/**
!Paper/**/
!Paper/**/*.tex
!Paper/**/*.bib

# Results, models, and logs (do not track - generated artifacts)
results/
*.zip
*.npz
*.joblib

# User requested exclusions
MY-RESEARCH.md
